{
  "name": "teller-ai-wrapper",
  "version": "0.1.0",
  "description": "Minimal pnpm/CLI wrapper that turns Teller account data into AI-ready financial context.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "teller-ai": "dist/cli.js",
    "financial-advisor": "dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "teller": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.14.0"
}
