# Teller API uses mutual TLS plus Basic Auth.
# Create/download your app certificate + private key in the Teller Dashboard.

# Teller Connect application ID (paste it into examples/login.html if you need a token).
TELLER_APPLICATION_ID=app_xxx

# Access token returned by Teller Connect for an enrollment.
TELLER_ACCESS_TOKEN=

# Either provide local file paths:
TELLER_CERT_PATH=./certs/certificate.pem
TELLER_KEY_PATH=./certs/private_key.pem

# Or provide PEM contents directly instead of paths. Use quoted strings with \n escapes.
# TELLER_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# TELLER_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional; defaults to production Teller API.
TELLER_API_BASE_URL=https://api.teller.io
